@layer base {
  * {
    @apply border-border outline-ring/50;
  }
  body {
    @apply bg-background text-foreground;
  }
}

/* ========================================
   THEME ENHANCEMENTS
   ======================================== */

/* Enhanced Card Styling with Theme Colors */
.blue .card,
.blue [data-slot="card"] {
  background: linear-gradient(to bottom, oklch(1 0 0), oklch(0.995 0.01 220));
  border: 1px solid oklch(0.85 0.04 220);
  box-shadow: 0 0 0 1px oklch(0.55 0.18 220 / 0.05), 0 1px 3px 0 oklch(0 0 0 / 0.1);
}

.blue-new .card,
.blue-new [data-slot="card"] {
  background: oklch(1 0 0);
  border: 1px solid oklch(0.475 0.144 264.05 / 0.15);
  border-left: 3px solid oklch(0.475 0.144 264.05);
  box-shadow: 0 0 0 1px oklch(0.475 0.144 264.05 / 0.05), 0 1px 3px 0 oklch(0.475 0.144 264.05 / 0.1);
}

.green .card,
.green [data-slot="card"] {
  background: linear-gradient(to bottom, oklch(1 0 0), oklch(0.995 0.01 145));
  border: 1px solid oklch(0.85 0.04 145);
  box-shadow: 0 0 0 1px oklch(0.5 0.15 145 / 0.05), 0 1px 3px 0 oklch(0 0 0 / 0.1);
}

.orange .card,
.orange [data-slot="card"] {
  background: linear-gradient(to bottom, oklch(1 0 0), oklch(0.995 0.01 35));
  border: 1px solid oklch(0.85 0.04 35);
  box-shadow: 0 0 0 1px oklch(0.58 0.19 35 / 0.05), 0 1px 3px 0 oklch(0 0 0 / 0.1);
}

.orange-gold .card,
.orange-gold [data-slot="card"] {
  background: linear-gradient(to bottom, oklch(1 0 0), oklch(0.99 0.02 45));
  border: 1px solid oklch(0.82 0.07 45);
  box-shadow: 0 0 0 1px oklch(0.6 0.2 40 / 0.05), 0 1px 3px 0 oklch(0 0 0 / 0.1);
}

.violet .card,
.violet [data-slot="card"] {
  background: linear-gradient(to bottom, oklch(1 0 0), oklch(0.995 0.01 290));
  border: 1px solid oklch(0.85 0.04 290);
  box-shadow: 0 0 0 1px oklch(0.52 0.18 290 / 0.05), 0 1px 3px 0 oklch(0 0 0 / 0.1);
}

.yellow .card,
.yellow [data-slot="card"] {
  background: linear-gradient(to bottom, oklch(1 0 0), oklch(0.995 0.01 95));
  border: 1px solid oklch(0.85 0.04 95);
  box-shadow: 0 0 0 1px oklch(0.62 0.18 85 / 0.05), 0 1px 3px 0 oklch(0 0 0 / 0.1);
}

.rose .card,
.rose [data-slot="card"] {
  background: linear-gradient(to bottom, oklch(1 0 0), oklch(0.995 0.01 10));
  border: 1px solid oklch(0.85 0.04 10);
  box-shadow: 0 0 0 1px oklch(0.55 0.2 10 / 0.05), 0 1px 3px 0 oklch(0 0 0 / 0.1);
}

/* Card Hover Effects with Ring - REMOVED */
/* .card:hover,
[data-slot="card"]:hover {
  box-shadow: 0 0 0 3px hsl(var(--primary) / 0.1), 0 4px 12px 0 hsl(var(--primary) / 0.15);
  transform: translateY(-2px);
  transition: all 0.2s ease;
} */

/* Card Focus Ring (for interactive cards) */
.card:focus-within,
[data-slot="card"]:focus-within {
  box-shadow: 0 0 0 3px hsl(var(--ring) / 0.3), 0 4px 12px 0 hsl(var(--primary) / 0.1);
  outline: none;
}

/* Glassmorphism for Modern Themes */
.blue-new .glass-card,
.violet .glass-card,
.rose .glass-card {
  background: hsl(var(--card) / 0.7);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid hsl(var(--border) / 0.5);
}

/* Section Headers with Theme Colors */
.section-header {
  border-left: 4px solid hsl(var(--primary));
  padding-left: 1rem;
  margin-bottom: 1.5rem;
}

/* Themed Badges */
.badge-primary {
  background: hsl(var(--primary) / 0.1);
  color: hsl(var(--primary));
  border: 1px solid hsl(var(--primary) / 0.2);
}

.badge-accent {
  background: hsl(var(--accent));
  color: hsl(var(--accent-foreground));
}

/* Enhanced Focus States */
*:focus-visible {
  outline: 2px solid hsl(var(--ring));
  outline-offset: 2px;
  border-radius: 0.375rem;
}

/* Themed Scrollbar */
.blue ::-webkit-scrollbar-thumb {
  background-color: oklch(0.55 0.18 220);
}

.blue-new ::-webkit-scrollbar-thumb {
  background-color: oklch(0.475 0.144 264.05);
}

.green ::-webkit-scrollbar-thumb {
  background-color: oklch(0.5 0.15 145);
}

.orange ::-webkit-scrollbar-thumb {
  background-color: oklch(0.58 0.19 35);
}

.orange-gold ::-webkit-scrollbar-thumb {
  background-color: oklch(0.6 0.2 40);
}

.violet ::-webkit-scrollbar-thumb {
  background-color: oklch(0.52 0.18 290);
}

.yellow ::-webkit-scrollbar-thumb {
  background-color: oklch(0.62 0.18 85);
}

.rose ::-webkit-scrollbar-thumb {
  background-color: oklch(0.55 0.2 10);
}

/* Enhanced Sidebar Styling */
.blue .sidebar,
.blue aside[data-slot="sidebar"] {
  background: linear-gradient(to bottom, oklch(0.98 0.02 220), oklch(0.96 0.03 220));
  border-color: oklch(0.88 0.04 220);
}

.blue-new .sidebar,
.blue-new aside[data-slot="sidebar"] {
  background: oklch(0.985 0 0);
  border-right: 1px solid oklch(0.475 0.144 264.05 / 0.1);
}

.green .sidebar,
.green aside[data-slot="sidebar"] {
  background: linear-gradient(to bottom, oklch(0.99 0.01 145), oklch(0.97 0.02 145));
  border-color: oklch(0.88 0.04 145);
}

.orange .sidebar,
.orange aside[data-slot="sidebar"] {
  background: linear-gradient(to bottom, oklch(0.99 0.01 35), oklch(0.97 0.02 35));
  border-color: oklch(0.88 0.04 35);
}

.orange-gold .sidebar,
.orange-gold aside[data-slot="sidebar"] {
  background: linear-gradient(to bottom, oklch(0.97 0.03 45), oklch(0.95 0.05 45));
  border-color: oklch(0.84 0.07 45);
}

.violet .sidebar,
.violet aside[data-slot="sidebar"] {
  background: linear-gradient(to bottom, oklch(0.99 0.01 290), oklch(0.97 0.02 290));
  border-color: oklch(0.88 0.04 290);
}

.yellow .sidebar,
.yellow aside[data-slot="sidebar"] {
  background: linear-gradient(to bottom, oklch(0.99 0.01 95), oklch(0.97 0.02 95));
  border-color: oklch(0.88 0.04 95);
}

.rose .sidebar,
.rose aside[data-slot="sidebar"] {
  background: linear-gradient(to bottom, oklch(0.99 0.01 10), oklch(0.97 0.02 10));
  border-color: oklch(0.88 0.04 10);
}

/* Active Sidebar Item Highlight */
.sidebar [data-active="true"],
aside[data-slot="sidebar"] [data-active="true"] {
  background: hsl(var(--primary) / 0.1);
  border-left: 3px solid hsl(var(--primary));
  font-weight: 500;
}

/* Themed Table Headers */
.table-header,
thead {
  background: hsl(var(--muted));
  border-bottom: 2px solid hsl(var(--primary) / 0.2);
}

/* Enhanced Table Styling with Theme Borders */
table {
  border: 1px solid hsl(var(--border));
  border-radius: 0.5rem;
  overflow: hidden;
}

.blue table {
  border: 1px solid oklch(0.85 0.04 220);
  box-shadow: 0 0 0 1px oklch(0.55 0.18 220 / 0.05);
}

.blue-new table {
  border: 1px solid oklch(0.475 0.144 264.05 / 0.15);
  box-shadow: 0 0 0 1px oklch(0.475 0.144 264.05 / 0.05);
}

.green table {
  border: 1px solid oklch(0.85 0.04 145);
  box-shadow: 0 0 0 1px oklch(0.5 0.15 145 / 0.05);
}

.orange table {
  border: 1px solid oklch(0.85 0.04 35);
  box-shadow: 0 0 0 1px oklch(0.58 0.19 35 / 0.05);
}

.orange-gold table {
  border: 1px solid oklch(0.82 0.07 45);
  box-shadow: 0 0 0 1px oklch(0.6 0.2 40 / 0.05);
}

.violet table {
  border: 1px solid oklch(0.85 0.04 290);
  box-shadow: 0 0 0 1px oklch(0.52 0.18 290 / 0.05);
}

.yellow table {
  border: 1px solid oklch(0.85 0.04 95);
  box-shadow: 0 0 0 1px oklch(0.62 0.18 85 / 0.05);
}

.rose table {
  border: 1px solid oklch(0.85 0.04 10);
  box-shadow: 0 0 0 1px oklch(0.55 0.2 10 / 0.05);
}

/* Table Row Hover Effects */
tbody tr:hover {
  background: hsl(var(--accent) / 0.5);
  transition: background-color 0.15s ease;
}

/* Table Header with Theme Accent */
thead th {
  font-weight: 600;
  text-transform: uppercase;
  font-size: 0.75rem;
  letter-spacing: 0.05em;
  color: hsl(var(--primary));
  padding: 0.75rem 1rem;
}

/* Striped Table Rows (optional - add .table-striped class) */
.table-striped tbody tr:nth-child(even) {
  background: hsl(var(--muted) / 0.3);
}

/* Page Background Enhancements */
.blue {
  background: oklch(0.985 0.015 220);
}

.blue-new {
  background: linear-gradient(to bottom, oklch(1 0 0), oklch(0.99 0.005 264));
}

.green {
  background: oklch(0.985 0.01 145);
}

.orange {
  background: oklch(0.985 0.01 35);
}

.orange-gold {
  background: oklch(0.98 0.02 45);
}

.violet {
  background: oklch(0.985 0.01 290);
}

.yellow {
  background: oklch(0.985 0.01 95);
}

.rose {
  background: oklch(0.985 0.01 10);
}

/* Main Content Area Background (Best Practice) */
main {
  background: transparent;
}

/* Page Container with Subtle Pattern (optional - add .page-pattern class) */
.page-pattern {
  background-image: 
    radial-gradient(circle at 20% 50%, hsl(var(--primary) / 0.03) 0%, transparent 50%),
    radial-gradient(circle at 80% 80%, hsl(var(--primary) / 0.02) 0%, transparent 50%);
}

/* Content Cards on Colored Background - Enhanced Contrast */
.blue .page-content .card,
.blue-new .page-content .card,
.green .page-content .card,
.orange .page-content .card,
.orange-gold .page-content .card,
.violet .page-content .card,
.yellow .page-content .card,
.rose .page-content .card {
  background: oklch(1 0 0);
  box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
}

/* Status Indicators with Theme Colors */
.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: hsl(var(--primary));
  box-shadow: 0 0 0 3px hsl(var(--primary) / 0.2);
}

/* ========================================
   UTILITY CLASSES - RINGS & BORDERS
   ======================================== */

/* Ring Utilities - Use these for focus/hover states */
.ring-sm {
  box-shadow: 0 0 0 2px hsl(var(--ring) / 0.2);
}

.ring {
  box-shadow: 0 0 0 3px hsl(var(--ring) / 0.3);
}

.ring-lg {
  box-shadow: 0 0 0 4px hsl(var(--ring) / 0.25);
}

.ring-primary {
  box-shadow: 0 0 0 3px hsl(var(--primary) / 0.2);
}

.ring-primary-hover:hover {
  box-shadow: 0 0 0 3px hsl(var(--primary) / 0.3);
}

/* Bordered Card Variations */
.card-bordered {
  border: 2px solid hsl(var(--border));
}

.card-bordered-primary {
  border: 2px solid hsl(var(--primary) / 0.3);
}

.card-bordered-top {
  border-top: 4px solid hsl(var(--primary));
}

.card-bordered-left {
  border-left: 4px solid hsl(var(--primary));
}

/* Interactive Card (clickable with ring on hover) - HOVER REMOVED */
.card-interactive {
  cursor: pointer;
  /* transition: all 0.2s ease; */
}

/* .card-interactive:hover {
  box-shadow: 0 0 0 3px hsl(var(--primary) / 0.1), 0 4px 12px 0 hsl(var(--primary) / 0.15);
  transform: translateY(-2px);
} */

.card-interactive:active {
  transform: translateY(0);
  box-shadow: 0 0 0 3px hsl(var(--primary) / 0.15), 0 2px 6px 0 hsl(var(--primary) / 0.1);
}

/* Elevated Card with Shadow Ring - HOVER REMOVED */
.card-elevated {
  box-shadow: 
    0 0 0 1px hsl(var(--border)),
    0 4px 6px -1px rgba(0, 0, 0, 0.1),
    0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

/* .card-elevated:hover {
  box-shadow: 
    0 0 0 1px hsl(var(--primary) / 0.3),
    0 10px 15px -3px rgba(0, 0, 0, 0.1),
    0 4px 6px -2px rgba(0, 0, 0, 0.05);
} */

/* ========================================
   BEST PRACTICE LAYOUT CLASSES
   ======================================== */

/* Page Container (wrap your main content) */
.page-container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 1.5rem;
}

/* Content Grid (for dashboard layouts) */
.content-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1.5rem;
}

/* Section Wrapper */
.section-wrapper {
  padding: 2rem 0;
  border-bottom: 1px solid hsl(var(--border));
}

.section-wrapper:last-child {
  border-bottom: none;
}

/* Floating Action Card (for forms, important actions) */
.floating-card {
  background: hsl(var(--card));
  border: 1px solid hsl(var(--border));
  border-radius: 0.75rem;
  padding: 1.5rem;
  box-shadow: 
    0 0 0 1px hsl(var(--primary) / 0.05),
    0 10px 15px -3px rgba(0, 0, 0, 0.1),
    0 4px 6px -2px rgba(0, 0, 0, 0.05);
}

/* ========================================
   END UTILITY CLASSES
   ======================================== */

/* Enhanced Button Hover States - REMOVED */
/* button:not(:disabled):hover,
[role="button"]:not(:disabled):hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 8px hsl(var(--primary) / 0.15);
  transition: all 0.2s ease;
} */

/* Smooth Theme Transitions - Excluded from popovers and calendars */
*:not([data-slot="popover-content"]):not([data-slot="calendar"]):not([data-radix-popper-content-wrapper]) {
  transition-property: background-color, border-color, color, fill, stroke;
  transition-duration: 200ms;
  transition-timing-function: ease-in-out;
}

/* Skip transitions for motion-sensitive users */
@media (prefers-reduced-motion: reduce) {
  * {
    transition: none !important;
  }
}

/* ========================================
   END THEME ENHANCEMENTS
   ======================================== */


/* RTL/LTR Utilities */
.rtl {
  direction: rtl;
}

.ltr {
  direction: ltr;
}

/* Main layout RTL/LTR */
.layout-rtl {
  flex-direction: row-reverse;
}

.layout-ltr {
  flex-direction: row;
}

/* Sidebar positioning utilities */
.sidebar-right {
  right: 0;
  left: auto;
  border-left: 1px solid hsl(var(--sidebar-border));
  border-right: none;
}

.sidebar-left {
  left: 0;
  right: auto;
  border-right: 1px solid hsl(var(--sidebar-border));
  border-left: none;
}

/* Toggle button positioning for RTL/LTR */
.toggle-button-rtl {
  left: -12px;
  right: auto;
}

.toggle-button-ltr {
  right: -12px;
  left: auto;
}

/* Icon spacing utilities */
.icon-spacing-rtl {
  margin-left: 0.75rem;
  margin-right: 0;
}

.icon-spacing-ltr {
  margin-right: 0.75rem;
  margin-left: 0;
}

/* Submenu indentation */
.submenu-indent-rtl {
  margin-right: 1rem;
  margin-left: 0;
}

.submenu-indent-ltr {
  margin-left: 1rem;
  margin-right: 0;
}

/* Badge positioning */
.badge-rtl {
  margin-right: auto;
  margin-left: 0;
}

.badge-ltr {
  margin-left: auto;
  margin-right: 0;
}

/* Font family utilities */
.font-arabic {
  font-family: var(--font-noto-arabic), 'Arial Unicode MS', 'Tahoma', 'Microsoft Sans Serif', 'Segoe UI', Arial, sans-serif;
}

.font-english {
  font-family: var(--font-inter), -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Helvetica Neue', Arial, sans-serif;
}

.font-sans {
  font-family: var(--font-inter), -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Helvetica Neue', Arial, sans-serif;
}

/* Language-specific font classes */
.lang-ar {
  font-family: var(--font-noto-arabic), 'Arial Unicode MS', 'Tahoma', 'Microsoft Sans Serif', 'Segoe UI', Arial, sans-serif;
  direction: rtl;
  text-align: right;
}

.lang-en {
  font-family: var(--font-inter), -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Helvetica Neue', Arial, sans-serif;
  direction: ltr;
  text-align: left;
}

/* Font weight utilities for Arabic fonts */
.font-arabic-light {
  font-family: var(--font-noto-arabic), 'Arial Unicode MS', 'Tahoma', 'Microsoft Sans Serif', 'Segoe UI', Arial, sans-serif;
  font-weight: 300;
}

.font-arabic-medium {
  font-family: var(--font-noto-arabic), 'Arial Unicode MS', 'Tahoma', 'Microsoft Sans Serif', 'Segoe UI', Arial, sans-serif;
  font-weight: 500;
}

.font-arabic-bold {
  font-family: var(--font-noto-arabic), 'Arial Unicode MS', 'Tahoma', 'Microsoft Sans Serif', 'Segoe UI', Arial, sans-serif;
  font-weight: 700;
}

/* Flex utilities for RTL */
.flex-rtl {
  display: flex;
  flex-direction: row-reverse;
}

.flex-ltr {
  display: flex;
  flex-direction: row;
}

/* Custom Scrollbar Styles */
.scrollbar-thin::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

.scrollbar-thin::-webkit-scrollbar-track {
  background-color: rgb(243 244 246);
  border-radius: 9999px;
}

.scrollbar-thin::-webkit-scrollbar-thumb {
  background-color: rgb(209 213 219);
  border-radius: 9999px;
  transition: background-color 0.2s ease;
}

.scrollbar-thin::-webkit-scrollbar-thumb:hover {
  background-color: rgb(156 163 175);
}

/* Firefox scrollbar */
.scrollbar-thin {
  scrollbar-width: thin;
  scrollbar-color: rgb(209 213 219) rgb(243 244 246);
}

/* Hide scrollbar for mobile tabs */
.scrollbar-hide {
  -ms-overflow-style: none;  /* IE and Edge */
  scrollbar-width: none;  /* Firefox */
}

.scrollbar-hide::-webkit-scrollbar {
  display: none;  /* Chrome, Safari and Opera */
}

/* Smooth scroll for tabs on mobile */
@media (max-width: 768px) {
  [data-slot="tabs-list"] {
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
  }
}

/* Print Styles - Hide everything except print content */
@media print {
  /* Hide navigation, sidebars, and headers */
  aside, header, nav, .sidebar, .navigation {
    display: none !important;
  }
  
  /* Hide print button when printing */
  .print-hide {
    display: none !important;
  }
  
  /* Critical: Remove all height and overflow restrictions */
  html, body {
    width: 100% !important;
    height: auto !important;
    max-height: none !important;
    min-height: 0 !important;
    overflow: visible !important;
    margin: 0 !important;
    padding: 0 !important;
  }
  
  /* Ensure the main content is visible and full width */
  main {
    width: 100% !important;
    max-width: 100% !important;
    height: auto !important;
    max-height: none !important;
    min-height: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: visible !important;
    position: static !important;
  }
  
  /* Full width for print container */
  .print-container {
    width: 100% !important;
    max-width: 100% !important;
    height: auto !important;
    max-height: none !important;
    min-height: 0 !important;
    margin: 0 !important;
    overflow: visible !important;
    position: static !important;
  }
  
  .print-full-width {
    width: 100% !important;
    max-width: 100% !important;
    height: auto !important;
    max-height: none !important;
    margin: 0 !important;
    padding: 1rem !important;
    overflow: visible !important;
  }
  
  /* Remove all overflow and height restrictions from divs */
  div {
    overflow: visible !important;
    max-height: none !important;
    height: auto !important;
  }
  
  /* Preserve colors and backgrounds */
  * {
    -webkit-print-color-adjust: exact !important;
    print-color-adjust: exact !important;
    color-adjust: exact !important;
  }
  
  /* Optimize page breaks */
  .print-avoid-break {
    page-break-inside: avoid !important;
    break-inside: avoid !important;
  }
  
  /* Allow page breaks in tables if needed */
  table {
    page-break-inside: auto !important;
  }
  
  tr {
    page-break-inside: avoid !important;
    page-break-after: auto !important;
  }
  
  thead {
    display: table-header-group !important;
  }
  
  /* Remove shadows for cleaner printing */
  .print-no-shadow {
    box-shadow: none !important;
  }
  
  /* Ensure proper page margins */
  @page {
    margin: 1.5cm;
    size: A4;
  }
  
  /* Hide scrollbars in print */
  ::-webkit-scrollbar {
    display: none !important;
  }
  
  /* Ensure all content is visible */
  * {
    overflow: visible !important;
  }
}

/* React Big Calendar Customization */
.rbc-calendar {
  font-family: inherit;
}

.rbc-header {
  padding: 12px 6px;
  font-weight: 600;
  border-bottom: 2px solid hsl(var(--border));
  background-color: hsl(var(--muted));
}

.rbc-month-view,
.rbc-time-view {
  border: 1px solid hsl(var(--border));
  border-radius: 8px;
  overflow: hidden;
}

.rbc-day-bg {
  border-left: 1px solid hsl(var(--border));
}

.rbc-today {
  background-color: hsl(var(--accent));
}

.rbc-off-range-bg {
  background-color: hsl(var(--muted) / 0.3);
}

.rbc-event {
  background-color: hsl(var(--primary));
  color: hsl(var(--primary-foreground));
  border: none;
  border-radius: 6px;
  padding: 4px 8px;
}

.rbc-event:hover {
  opacity: 0.85;
}

.rbc-event-label {
  font-size: 12px;
}

.rbc-toolbar {
  padding: 16px;
  margin-bottom: 16px;
  background-color: hsl(var(--card));
  border-radius: 8px;
  border: 1px solid hsl(var(--border));
}

.rbc-toolbar button {
  color: hsl(var(--foreground));
  border: 1px solid hsl(var(--border));
  padding: 8px 16px;
  border-radius: 6px;
  background-color: hsl(var(--background));
  transition: all 0.2s;
}

.rbc-toolbar button:hover {
  background-color: hsl(var(--accent));
}

.rbc-toolbar button.rbc-active {
  background-color: hsl(var(--primary));
  color: hsl(var(--primary-foreground));
  border-color: hsl(var(--primary));
}

.rbc-time-slot {
  border-top: 1px solid hsl(var(--border));
}

.rbc-agenda-view {
  border: 1px solid hsl(var(--border));
  border-radius: 8px;
}

.rbc-agenda-table {
  border-spacing: 0;
}

.rbc-agenda-date-cell,
.rbc-agenda-time-cell {
  padding: 12px;
  border-left: 1px solid hsl(var(--border));
}

.rbc-agenda-event-cell {
  padding: 12px;
}
